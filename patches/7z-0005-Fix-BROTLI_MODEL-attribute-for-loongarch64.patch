Subject: Fix BROTLI_MODEL attribute for loongarch64

The GCC 'model' attribute is not supported on loongarch64, causing build
errors like "invalid argument of 'model' attribute". Add a guard to
disable the attribute on loongarch64, consistent with the upstream fix.

Origin: upstream, https://github.com/google/brotli
---
 C/brotli/common/platform.h | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/C/brotli/common/platform.h b/C/brotli/common/platform.h
index 8efd24e..c8a77f5 100644
--- a/C/brotli/common/platform.h
+++ b/C/brotli/common/platform.h
@@ -666,7 +666,8 @@
 #endif
 
-#if BROTLI_GNUC_HAS_ATTRIBUTE(model, 3, 0, 3)
+#if BROTLI_GNUC_HAS_ATTRIBUTE(model, 3, 0, 3) && \
+    !defined(BROTLI_TARGET_LOONGARCH64)
 #define BROTLI_MODEL(M) __attribute__((model(M)))
 #else
 #define BROTLI_MODEL(M) /* M */
 #endif
